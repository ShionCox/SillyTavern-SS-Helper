# 功能：为 MemoryOS 的 aitest 接口联调测试提供示例环境变量。
# 用法：复制为同目录下的 `.env.memoryos.test`，按你的实际接口填写。

# 大模型生成接口
MEMORYOS_TEST_GENERATION_URL=
MEMORYOS_TEST_GENERATION_KEY=
MEMORYOS_TEST_GENERATION_MODEL=
MEMORYOS_TEST_GENERATION_HEADERS=
MEMORYOS_TEST_GENERATION_BODY_JSON=

# 向量接口
MEMORYOS_TEST_EMBED_URL=
MEMORYOS_TEST_EMBED_KEY=
MEMORYOS_TEST_EMBED_MODEL=
MEMORYOS_TEST_EMBED_HEADERS=
MEMORYOS_TEST_EMBED_BODY_JSON=

# 重排接口
MEMORYOS_TEST_RERANK_URL=
MEMORYOS_TEST_RERANK_KEY=
MEMORYOS_TEST_RERANK_MODEL=
MEMORYOS_TEST_RERANK_HEADERS=
MEMORYOS_TEST_RERANK_BODY_JSON=
