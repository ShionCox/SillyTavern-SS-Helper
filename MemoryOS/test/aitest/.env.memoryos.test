# 功能：为 MemoryOS 的 vitest 接口联调测试提供示例环境变量。
# 用法：复制为 `.env.memoryos.test`，按你的实际接口填写。

# 大模型生成接口（兼容 OpenAI chat/completions 风格）
MEMORYOS_TEST_GENERATION_URL="https://api.deepseek.com/v1"
MEMORYOS_TEST_GENERATION_KEY="sk-bffe89dd9daf45e1bff18301addc14d8"
MEMORYOS_TEST_GENERATION_MODEL="deepseek-chat"
# 可选：自定义请求头，JSON 对象
MEMORYOS_TEST_GENERATION_HEADERS=""
# 可选：附加请求体，JSON 对象
MEMORYOS_TEST_GENERATION_BODY_JSON=""

# 向量接口（兼容 OpenAI embeddings 风格）
MEMORYOS_TEST_EMBED_URL="https://ai.gitee.com/v1"
MEMORYOS_TEST_EMBED_KEY="XA9URTOYJTLCKQF3J5J6CGBAOFFPDPSJIILI5D6O"
MEMORYOS_TEST_EMBED_MODEL="Qwen3-Embedding-8B"
MEMORYOS_TEST_EMBED_HEADERS=""
MEMORYOS_TEST_EMBED_BODY_JSON=""

# 重排接口（兼容 query + documents + top_n 风格）
MEMORYOS_TEST_RERANK_URL="https://ai.gitee.com/v1/rerank"
MEMORYOS_TEST_RERANK_KEY="XA9URTOYJTLCKQF3J5J6CGBAOFFPDPSJIILI5D6O"
MEMORYOS_TEST_RERANK_MODEL="Qwen3-Reranker-4B"
MEMORYOS_TEST_RERANK_HEADERS=""
MEMORYOS_TEST_RERANK_BODY_JSON=""
