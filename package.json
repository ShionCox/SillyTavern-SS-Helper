{
    "name": "ss-helper-workspace",
    "private": true,
    "scripts": {
        "install:all": "pnpm install",
        "build": "node scripts/vite-build.mjs",
        "build:watch": "node scripts/vite-build.mjs --watch",
        "build:memory": "node scripts/vite-build.mjs MemoryOS",
        "build:llm": "node scripts/vite-build.mjs LLMHub",
        "build:roll": "node scripts/vite-build.mjs RollHelper",
        "vite:build": "node scripts/vite-build.mjs",
        "vite:watch": "node scripts/vite-build.mjs --watch",
        "vite:build:memory": "node scripts/vite-build.mjs MemoryOS",
        "vite:build:llm": "node scripts/vite-build.mjs LLMHub",
        "vite:build:roll": "node scripts/vite-build.mjs RollHelper",
        "memory:test": "vite serve MemoryOS/testbed --config MemoryOS/testbed/vite.config.ts",
        "watch:memory": "node scripts/vite-build.mjs MemoryOS --watch",
        "watch:llm": "node scripts/vite-build.mjs LLMHub --watch",
        "watch:roll": "node scripts/vite-build.mjs RollHelper --watch",
        "roll:test": "vite serve RollHelper/test",
        "clean": "rm -rf MemoryOS/dist LLMHub/dist RollHelper/dist"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.2.1",
        "autoprefixer": "^10.4.27",
        "esbuild": "^0.23.0",
        "gsap": "^3.14.2",
        "pinia": "^3.0.4",
        "pixi.js": "^8.17.1",
        "postcss": "^8.5.8",
        "tailwindcss": "^4.2.1",
        "vite": "^8.0.0"
    },
    "dependencies": {
        "dexie": "^4.3.0",
        "zod": "^4.3.6"
    }
}
